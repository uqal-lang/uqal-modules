// PostGIS grammar extension
// Adds spatial condition functions: ST_Within, ST_Intersects, ST_DWithin

postgis_condition: st_within
                 | st_intersects
                 | st_dwithin

st_within: "ST_Within" "(" CNAME "," string_literal ")"
st_intersects: "ST_Intersects" "(" CNAME "," string_literal ")"
st_dwithin: "ST_DWithin" "(" CNAME "," string_literal "," NUMBER ")"
