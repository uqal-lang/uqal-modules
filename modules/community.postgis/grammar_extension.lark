// PostGIS grammar extension
// Adds spatial condition functions: ST_Within, ST_Intersects, ST_DWithin
%import common.NUMBER

postgis_condition: st_within
                 | st_intersects
                 | st_dwithin

st_within:     "ST_Within"     "(" NAME "," string_lit ")"
st_intersects: "ST_Intersects" "(" NAME "," string_lit ")"
st_dwithin:    "ST_DWithin"    "(" NAME "," string_lit "," NUMBER ")"
